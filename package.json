{
  "name": "dissolution-web",
  "version": "0.0.1",
  "description": "This is a Node.js frontend application for the Companies House dissolution service.",
  "main": "dist/app.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "url": "https://github.com/companieshouse/dissolution-web"
  },
  "license": "MIT",
  "scripts": {
    "start": "node dist/app.js",
    "build": "gulp build",
    "build:clean": "gulp build:clean",
    "lint": "eslint 'src/*.ts' 'src/**/*.ts' 'test/**/*.ts'",
    "lint:fix": "eslint 'src/*.ts' 'src/**/*.ts' 'test/**/*.ts' --fix",
    "test": "mocha 'test/**/*.test.ts'",
    "test:coverage": "nyc npm test",
    "start:watch": "nodemon",
    "chs-dev": "nodemon --legacy-watch",
    "sonarqube-base-branch": "sonar-scanner",
    "sonarqube-pull-request": "sonar-scanner -D sonar.pullrequest.base=master",
    "sonarqube": "branch=$(git rev-parse --symbolic-full-name --abbrev-ref HEAD); if [[ $branch == \"HEAD\" ]]; then echo $branch && npm run sonarqube-base-branch; else echo $branch && npm run sonarqube-pull-request; fi;"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@companieshouse/api-sdk-node": "^2.0.345",
    "@companieshouse/node-session-handler": "^5.2.14",
    "@companieshouse/structured-logging-node": "^2.0.13",
    "@companieshouse/web-security-node": "^4.4.20",
    "@hapi/joi": "^17.1.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.218.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/baggage-span-processor": "^0.5.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.218.0",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "axios": "^1.16.1",
    "body-parser": "^1.20.5",
    "cookie-parser": "^1.4.7",
    "crypto": "^1.0.1",
    "dashify": "^2.0.0",
    "express": "^4.22.1",
    "govuk-frontend": "^3.15.0",
    "helmet": "^4.6.0",
    "http-status-codes": "^2.3.0",
    "inversify": "^6.2.2",
    "inversify-binding-decorators": "^4.0.0",
    "inversify-express-utils": "6.4.10",
    "lodash": "^4.17.23",
    "moment": "^2.30.1",
    "nocache": "^2.1.0",
    "node-jose": "^2.2.0",
    "nunjucks": "^3.2.4",
    "reflect-metadata": "^0.2.2",
    "tsconfig-paths": "^3.15.0",
    "tslib": "^2.8.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/chai": "^5.2.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/dashify": "^1.0.3",
    "@types/express": "4.17.21",
    "@types/hapi__joi": "^17.1.15",
    "@types/ioredis": "^4.28.10",
    "@types/jsdom": "^16.2.15",
    "@types/lodash": "^4.17.24",
    "@types/mocha": "^10.0.10",
    "@types/multer": "^1.4.13",
    "@types/node-jose": "^1.1.13",
    "@types/nunjucks": "^3.2.6",
    "@types/sinon": "^21.0.1",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "chai": "^6.2.2",
    "del": "^6.1.1",
    "eslint": "^10.2.1",
    "gulp": "^5.0.1",
    "gulp-typescript": "^6.0.0-alpha.1",
    "jsdom": "^26.1.0",
    "minimist": "^1.2.8",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.14",
    "nyc": "^18.0.0",
    "sinon": "^21.1.2",
    "sonarqube-scanner": "^4.3.6",
    "supertest": "^7.2.2",
    "ts-mockito": "^2.6.1",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5"
  },
  "overrides": {
    "fast-xml-parser": "^5.3.8",
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.3",
    "uuid": "^14.0.0",
    "protobufjs": "8.0.3",
    "axios": "^1.16.1"
  },
  "nodemonConfig": {
    "watch": [
      "./src"
    ],
    "ext": "ts,js,json,njk,scss,env",
    "legacyWatch": true,
    "ignore": [
      "**/*.test.ts"
    ],
    "exec": "node --inspect=0 -r ts-node/register src/app.ts"
  }
}
