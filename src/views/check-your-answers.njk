{% extends 'layout.njk' %}

{% from 'govuk/components/back-link/macro.njk'     import govukBackLink %}
{% from 'govuk/components/button/macro.njk'        import govukButton %}
{% from "govuk/components/summary-list/macro.njk"  import govukSummaryList %}

{% set title = "Check your answers - " + pageTitleSuffix %}

{% block content %}
  {{
    govukBackLink({
      text: 'Back',
      href: backUri
    })
  }}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">Check your answers</h1>
      {% for director in directors %}
        <h2 class="govuk-heading-m director-name-header">{{ director.name }}</h2>
        {{
          govukSummaryList({
            classes: 'govuk-!-margin-bottom-4',
            attributes: { id: 'director-details-' + loop.index0 },
            rows: [
              {
                key: {
                  text: "Name"
                },
                value: {
                  text: director.onBehalfName or director.name
                },
                classes: ('director-on-behalf-name' if director.onBehalfName else 'director-name')
              },
              {
                key: {
                  text: "Email address"
                },
                value: {
                  text: director.email
                },
                actions: {
                  items: [{
                    href:  Paths.APPLICATION_STATUS_URI + '/' + director.id + '/change?check_answers=true',
                    text: "Change",
                    visuallyHiddenText: "email address for " + (director.onBehalfName or director.name),
                    attributes: {
                      'data-event-id': 'change-email-link'
                    }
                  }]
                },
                classes: "director-email"
              }
            ]
          })
        }}
      {% endfor %}

      {% if isMultiDirector %}
        <p class="govuk-body govuk-!-margin-top-4">
          <a id="change-signatories" class="govuk-link" data-event-id="change-which-director-will-sign-link" href="{{ Paths.SELECT_SIGNATORIES_URI }}">Change which director will sign</a>
        </p>
      {% endif %}

      <form method="post">

        {% include "components/csrf_token.njk" %}

        {{
          govukButton({
            text: 'Continue',
            attributes: {
              id: 'submit'
            }
          })
        }}
      </form>
    </div>
  </div>
{% endblock %}
