{#
  matomo-checkbox-submit-tracking.njk
  -----------------------------------
  Purpose: Adds a script to track checked checkboxes with Matomo analytics when a submit button is clicked.
  Usage: Include this partial in any Nunjucks view where checkbox tracking is needed.
  Expects the following variables to be available in the view:
    - matomo: boolean, enables/disables the script
    - nonce: string, for CSP compliance
    - title: string, used as the event category (e.g., page or section title)
  Behaviour: For each checked checkbox, the script will push the value of its data-event-value attribute to Matomo. If data-event-value is not present, it will use the checkbox's id as the value. To control the tracked value, specify a data-event-value attribute on the checkbox input.
#}

{% if piwik %}
 <script nonce={{ nonce | dump | safe }}>
     $(document).ready(function () {
       $('#submit').on('click', function () {
         $('input[type=checkbox]:checked').each(function () {
           var eventValue = $(this).attr('data-event-value');
           var valueToPush = eventValue ? eventValue : $(this).attr('id');
           if (valueToPush) {
             _paq.push(['trackEvent', {{ ('dissolutions ' ~ title) | dump}}, valueToPush]);
           }
         });
       });
     });
 </script>
{% endif %}
